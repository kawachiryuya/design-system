{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$description": "Semantic color tokens. WHERE (background/surface/onSurface/border/state) × WHAT (default/muted/primary/...). Values reference primitives in colors.json. CSS vars: --color-{where}-{what}",
  "background": {
    "default":  { "value": "white",       "description": "ページ最下層" }
  },
  "surface": {
    "default":  { "value": "white",       "description": "カード・モーダル" },
    "raised":   { "value": "neutral-50",  "description": "入れ子サーフェス" },
    "overlay":  { "value": "black/50",    "description": "モーダルオーバーレイ" },
    "primary":   { "value": "primary-600", "description": "主要アクション（Primaryボタン等）" },
    "secondary": { "value": "primary-50",  "description": "選択状態・アクティブ項目" },
    "success":        { "value": "success-500", "description": "成功の強調塗り（バッジ・ドット等）" },
    "success-muted":  { "value": "success-50",  "description": "成功Alert背景等" },
    "error":          { "value": "error-500",   "description": "エラーの強調塗り（バッジ・ドット等）" },
    "error-muted":    { "value": "error-50",    "description": "エラーAlert背景等" },
    "warning":        { "value": "warning-400", "description": "警告の強調塗り（バッジ・ドット等）" },
    "warning-muted":  { "value": "warning-50",  "description": "警告Alert背景等" },
    "info":           { "value": "info-500",    "description": "情報の強調塗り（バッジ・ドット等）" },
    "info-muted":     { "value": "info-50",     "description": "情報Alert背景等" },
    "disabled":  { "value": "neutral-100", "description": "非活性エリア" },
    "skeleton":  { "value": "neutral-200", "description": "スケルトンローディング" },
    "neutral":   { "value": "neutral-400", "description": "オフライン等のミュートな塗り" },
    "inset":     { "value": "neutral-100", "description": "凹み・控えめな背景（neutral Alert等）" }
  },
  "onSurface": {
    "default":  { "value": "neutral-900", "description": "主テキスト" },
    "muted":    { "value": "neutral-500", "description": "サブテキスト・プレースホルダー" },
    "subtle":   { "value": "neutral-400", "description": "最も控えめなテキスト" },
    "primary":  { "value": "primary-600", "description": "リンク・CTA" },
    "success":  { "value": "success-700", "description": "成功テキスト・アイコン" },
    "error":    { "value": "error-700",   "description": "エラーテキスト" },
    "warning":  { "value": "warning-700", "description": "警告テキスト" },
    "info":     { "value": "info-700",    "description": "情報テキスト" },
    "disabled": { "value": "neutral-400", "description": "非活性テキスト" },
    "inverse":  { "value": "white",       "description": "色面上テキスト（Primaryボタン等）" }
  },
  "border": {
    "default":  { "value": "neutral-300", "description": "標準ボーダー" },
    "muted":    { "value": "neutral-200", "description": "薄いボーダー" },
    "strong":   { "value": "neutral-400", "description": "強調ボーダー" },
    "focus":    { "value": "primary-600", "description": "フォーカスリング" },
    "primary":  { "value": "primary-600", "description": "選択・アクティブ枠" },
    "error":    { "value": "error-600",   "description": "エラー枠" },
    "disabled": { "value": "neutral-200", "description": "非活性ボーダー" },
    "success-muted": { "value": "success-200", "description": "成功コンテナ枠（Alert等）" },
    "error-muted":   { "value": "error-200",   "description": "エラーコンテナ枠（Alert等）" },
    "warning-muted": { "value": "warning-200", "description": "警告コンテナ枠（Alert等）" },
    "info-muted":    { "value": "info-200",    "description": "情報コンテナ枠（Alert等）" }
  },
  "state": {
    "hover":    { "value": "black/8",     "description": "ホバーオーバーレイ" },
    "active":   { "value": "black/12",    "description": "アクティブオーバーレイ" },
    "dragged":  { "value": "black/16",    "description": "ドラッグ中オーバーレイ" }
  }
}
